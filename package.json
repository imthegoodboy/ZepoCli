{
  "name": "zepocli",
  "version": "0.1.0",
  "description": "Terminal-first CLI for user-directed Zepto shopping workflows.",
  "type": "module",
  "bin": {
    "zepo": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "verify:cli": "node scripts/verify-cli.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "check": "npm run build && npm test && npm run verify:cli && npm run verify:package && npm pack --dry-run",
    "prepack": "npm run build",
    "prepare:browsers": "playwright install chromium"
  },
  "engines": {
    "node": ">=20.11"
  },
  "keywords": [
    "zepto",
    "cli",
    "playwright",
    "shopping"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imthegoodboy/ZepoCli.git"
  },
  "bugs": {
    "url": "https://github.com/imthegoodboy/ZepoCli/issues"
  },
  "homepage": "https://github.com/imthegoodboy/ZepoCli#readme",
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "fuse.js": "^7.1.0",
    "ora": "^9.0.0",
    "pino": "^10.1.0",
    "playwright": "^1.57.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
